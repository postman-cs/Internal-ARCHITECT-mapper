# Database — PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/architect_mapper?schema=public"

# Session secret — must be at least 32 characters
# Generate with: openssl rand -base64 48
SESSION_SECRET="change-me-to-a-real-secret-at-least-32-chars-long"

# Optional: Webhook secret for /api/webhooks/architect-ingest
# WEBHOOK_SECRET="your-webhook-secret"
